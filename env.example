# ── Shaddies Checker — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# On Railway: set these directly in the Railway dashboard (Variables tab).

# Hugging Face — AI detection + semantic embeddings (replaces Anthropic)
# Get your free token at: huggingface.co/settings/tokens
# Free tier: 30,000 requests/month
HF_API_KEY=your_huggingface_token_here

# DeepSeek — paraphrasing + humanization (single merged call)
# Get from: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Brave Search — web plagiarism (free tier: 2,000 queries/month)
# Get from: brave.com/search/api
BRAVE_API_KEY=your_brave_api_key_here

# Shared secret between this service and your Next.js app
# Generate with: openssl rand -hex 32
# Must be identical in both Railway and Vercel env vars
INTERNAL_API_SECRET=change_this_to_a_long_random_secret
