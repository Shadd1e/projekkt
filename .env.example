# ── Projekkt Python Microservice ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Anthropic — Claude API (AI detection)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek — paraphrasing + humanization
# Get from: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Brave Search — web plagiarism check
# Get from: brave.com/search/api (free tier: 2,000 queries/month)
BRAVE_API_KEY=your_brave_api_key_here

# Shared secret between this service and your Next.js app
# Generate with: openssl rand -hex 32
# Must be identical in both Railway and Vercel env vars
INTERNAL_API_SECRET=change_this_to_a_long_random_secret
