# ── Shaddies Checker — Python Microservice ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# DeepSeek API key (paraphrasing + humanization)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Brave Search API key (web plagiarism check)
BRAVE_API_KEY=your_brave_api_key_here

# Shared secret between this service and your Next.js backend
# Generate a strong random string e.g: openssl rand -hex 32
INTERNAL_API_SECRET=change_this_to_a_long_random_secret
